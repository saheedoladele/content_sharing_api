# Copy to `.env` and/or `.env.dev` (see below). Do not commit real secrets.

PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/content-sharing
JWT_SECRET=
JWT_EXPIRES_IN=7d
CLOUDINARY_URL=

# Loading order (from `backend/` directory):
# 1. `.env`
# 2. `.env.dev` if the file exists — values override `.env`
# Use `.env.dev` for local credentials (gitignored).
